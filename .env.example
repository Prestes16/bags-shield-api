# =============================================================================
# Bags Shield API — .env.example
# Copie para .env / .env.local conforme o ambiente. NUNCA comite segredos reais.
# =============================================================================

# === Runtime Auth (header Authorization: Bearer <BAGS_BEARER>) ===
# Em PROD, use um valor forte/aleatório. Aqui é só placeholder.
BAGS_BEARER=change-me-in-prod

# === (Opcional) Upstream/mocks/tuning ===
# Base alternativa de upstream para DEV/mocks. Em PROD, deixe vazio.
# Ex.: https://bags-shield-api.vercel.app/api/mock
BAGS_API_BASE=
# Timeout (ms) para chamadas upstream (safe default)
BAGS_TIMEOUT_MS=5000

# === Integração Bags (quando habilitarmos os endpoints /api/bags/*) ===
# Chave da Bags Public API. NÃO comitar real.
BAGS_API_KEY=
# RPC Solana / Helius — aceita UM dos dois (obrigatório para /api/scan):
# HELIUS_RPC_URL: URL completa (ex: https://mainnet.helius-rpc.com/?api-key=YOUR_KEY)
# HELIUS_API_KEY: só a key (len>=30). Usado se HELIUS_RPC_URL não estiver definido.
# APIs Enhanced: Parse Transaction(s), Parse Transaction History usam api-mainnet.helius-rpc.com com esta key.
# SOLANA_RPC_URL: URL customizada (ex: devnet, outro provedor)
HELIUS_RPC_URL=
HELIUS_API_KEY=
SOLANA_RPC_URL=

# === Webhooks/integrações ===
# Segredo para validar HMAC do webhook da Vercel (x-vercel-signature)
INTEGRATION_SECRET=

# === Ferramentas locais / CLI (NÃO em rotas serverless) ===
# Token pessoal da Vercel para scripts locais (deploy/alias).
VERCEL_TOKEN=

# === (Opcional) CORS ===
# Se lib/cors.ts suportar múltiplas origins via env, liste separadas por vírgula.
# Ex.: http://localhost:5173,https://bags-shield-api.vercel.app
ALLOWED_ORIGINS=

# === Scan extras (opcional) ===
# BIRDEYE_API_KEY: Birdeye token_overview API (se não definir, birdeye=down no scan; confidence reduzida)

# === Token Creator (Beta: desligado) ===
# FEATURE_TOKEN_CREATOR=false — scaffold apenas; rotas retornam 501 até implementação futura
FEATURE_TOKEN_CREATOR=false

# === Bags Shield API Backend (para proxy routes) ===
# Base URL do backend real da Bags Shield API (Vercel)
# Quando configurado, as rotas /api/scan e /api/simulate fazem proxy para este backend
# Ex.: https://bags-shield-api.vercel.app
BAGS_SHIELD_API_BASE=

# === Swap / Jupiter fees (server-side only) ===
# Jupiter Swap V2 /order referral fees require an API key plus referral account.
# The USDC collector ATA for the treasury is deterministic:
# 2shi8gXPJmv2EU4fUKnQiMHRXgQGA1eDTpFvo6HMAkZz
JUPITER_API_KEY=
JUPITER_REFERRAL_ACCOUNT=FzdTbo3noKJLQFNbVEZEowq5JHKpqQpGhhguWvDkRwSY
APP_FEE_BPS=50
APP_FEE_COLLECTOR_OWNER=7ZybPucnSryE5BydcARdc4Q2gz1SaospMVRyQ2LCeyRi
BETA_TRADING_ENABLED=true

# === Launchpad Bags v2 / Fees (server-side only) ===
LAUNCHPAD_ENABLED=true
LAUNCHPAD_MODE=real
LAUNCHPAD_FEES_ENABLED=true
LAUNCHPAD_TREASURY_WALLET=7ZybPucnSryE5BydcARdc4Q2gz1SaospMVRyQ2LCeyRi
LAUNCHPAD_BASE_FEE_LAMPORTS=20000000
LAUNCHPAD_VERIFIED_FEE_LAMPORTS=30000000
LAUNCHPAD_LIQUIDITY_FREE_THRESHOLD_LAMPORTS=250000000
LAUNCHPAD_LIQUIDITY_TIER_1_END_LAMPORTS=2000000000
LAUNCHPAD_LIQUIDITY_TIER_2_END_LAMPORTS=10000000000
LAUNCHPAD_LIQUIDITY_FEE_BPS_LOW=125
LAUNCHPAD_LIQUIDITY_FEE_BPS_MID=100
LAUNCHPAD_LIQUIDITY_FEE_BPS_HIGH=75
LAUNCHPAD_LIQUIDITY_FEE_CAP_LAMPORTS=250000000
LAUNCHPAD_FEE_SHARE_BPS=500
LAUNCHPAD_CREATOR_SHARE_BPS=9500
LAUNCHPAD_FEE_MODE=tipWallet_plus_feeShare

# === Scan Security (Anti-Forgery) ===
# HMAC secret for signing scan results to prevent data forgery
# Use a strong random string (32+ characters) in production
SCAN_HMAC_SECRET=your-scan-hmac-secret-key-here-use-32-plus-chars

# === OAuth Social Login ===
# Google — https://console.cloud.google.com > APIs & Services > Credentials
# Create OAuth 2.0 Client ID (Web), then add Authorized redirect URI:
#   https://api.bagsshield.org/api/auth/google/callback
# (same value as AUTH_CALLBACK_BASE + /api/auth/google/callback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Twitter/X — https://developer.twitter.com > Project > App Settings > OAuth 2.0
# Callback URL:  https://api.bagsshield.org/api/auth/twitter/callback
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Base URL of THIS API server (no trailing slash).
# The OAuth callback redirect_uri is: AUTH_CALLBACK_BASE + /api/auth/google/callback
# This value MUST match exactly what is registered in Google/Twitter developer consoles.
# Default (if unset): https://api.bagsshield.org
AUTH_CALLBACK_BASE=https://api.bagsshield.org

# Base URL of the FRONTEND app — where the user lands after OAuth success/failure.
# Default (if unset): https://app.bagsshield.org
FRONTEND_URL=https://app.bagsshield.org

# JWT secret for signing auth tokens. Use a strong random string (32+ chars) in prod.
AUTH_JWT_SECRET=change-me-in-prod

# === Frontend client components ===
NEXT_PUBLIC_API_BASE=
NEXT_PUBLIC_SOLANA_RPC=
